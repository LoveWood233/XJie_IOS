<view class="chat-page">
  <!-- 顶部工具栏 -->
  <view class="chat-toolbar">
    <view class="toolbar-btn" bindtap="newChat">
      <text>+ 新对话</text>
    </view>
    <view class="toolbar-btn" bindtap="toggleHistory">
      <text>📋 历史</text>
    </view>
  </view>

  <!-- 历史会话列表 -->
  <view class="history-panel" wx:if="{{showHistory}}">
    <view class="history-item" wx:for="{{conversations}}" wx:key="id" data-id="{{item.id}}" bindtap="loadConversation">
      <text class="history-title">{{item.title || '对话'}}</text>
      <text class="text-muted">{{item.message_count}} 条消息</text>
    </view>
    <view class="empty-hint" wx:if="{{conversations.length === 0}}">
      <text class="text-muted">暂无历史对话</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view scroll-y class="message-list" scroll-into-view="msg-bottom">
    <view wx:if="{{messages.length === 0}}" class="welcome-msg">
      <text class="robot-icon">🤖</text>
      <text class="welcome-text">你好！我是你的健康AI助手。</text>
      <text class="welcome-sub">可以问我关于血糖、膳食、健康管理的问题。</text>
    </view>

    <view wx:for="{{messages}}" wx:key="index" class="msg-row {{item.role === 'user' ? 'msg-user' : 'msg-assistant'}}">
      <view class="msg-bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-assistant'}}">
        <text class="msg-text">{{item.content}}</text>
      </view>
      <!-- 推荐问题 -->
      <view class="followups" wx:if="{{item.followups && item.followups.length > 0}}">
        <view class="followup-item" wx:for="{{item.followups}}" wx:for-item="q" wx:key="*this" data-text="{{q}}" bindtap="onFollowup">
          <text>{{q}}</text>
        </view>
      </view>
    </view>

    <!-- 发送中提示 -->
    <view class="msg-row msg-assistant" wx:if="{{sending}}">
      <view class="bubble-assistant typing">
        <text class="msg-text">思考中...</text>
      </view>
    </view>

    <view id="msg-bottom"></view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar">
    <input
      class="chat-input"
      placeholder="输入消息..."
      value="{{inputValue}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <view class="send-btn {{inputValue && !sending ? 'send-active' : ''}}" bindtap="sendMessage">
      <text>发送</text>
    </view>
  </view>
</view>
