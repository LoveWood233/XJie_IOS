<view class="container">
  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- AI 总结卡片 -->
    <view class="card ai-card" bindtap="generateSummary">
      <view class="card-header">
        <text class="card-icon">🤖</text>
        <text class="card-title">AI 健康总结</text>
        <text class="refresh-btn {{generatingSummary ? 'spinning' : ''}}">🔄</text>
      </view>
      <view class="summary-body" wx:if="{{summary}}">
        <text class="summary-text">{{summary}}</text>
        <text class="summary-time" wx:if="{{summaryUpdatedAt}}">更新于 {{summaryUpdatedAt}}</text>
      </view>
      <view class="summary-empty" wx:else>
        <text class="empty-hint">点击生成 AI 健康总结</text>
        <text class="empty-sub">将综合您的所有病例和体检数据进行分析</text>
      </view>
    </view>

    <!-- 历史病例 -->
    <view class="card section-card" bindtap="goRecords">
      <view class="section-row">
        <view class="section-left">
          <text class="section-icon">📋</text>
          <view class="section-info">
            <text class="section-title">历史病例</text>
            <text class="section-count">{{recordCount}} 份记录</text>
          </view>
        </view>
        <view class="section-right">
          <text class="upload-tag">可上传</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 历史体检 -->
    <view class="card section-card" bindtap="goExams">
      <view class="section-row">
        <view class="section-left">
          <text class="section-icon">🔬</text>
          <view class="section-info">
            <text class="section-title">历史体检</text>
            <text class="section-count">{{examCount}} 份报告</text>
          </view>
        </view>
        <view class="section-right">
          <text class="upload-tag">可上传</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 底部快捷上传 -->
    <view class="upload-bar" bindtap="quickUpload">
      <text class="upload-icon">📷</text>
      <text class="upload-text">拍照 / 文件上传</text>
    </view>
  </block>
</view>
