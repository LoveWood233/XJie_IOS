/* ── AI 总结卡片 ── */
.ai-card {
  position: relative;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-icon {
  font-size: 36rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  flex: 1;
}

.refresh-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

.spinning {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.summary-body {
  padding: 0 8rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.7;
  white-space: pre-wrap;
}

.summary-time {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 16rpx;
  text-align: right;
}

.summary-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #6366f1;
  font-weight: 500;
}

.empty-sub {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

/* ── 板块卡片 ── */
.section-card {
  padding: 28rpx 32rpx;
}

.section-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.section-icon {
  font-size: 44rpx;
}

.section-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-count {
  font-size: 24rpx;
  color: #94a3b8;
}

.section-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.upload-tag {
  font-size: 22rpx;
  color: #6366f1;
  background: rgba(99, 102, 241, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* ── 底部上传栏 ── */
.upload-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(99, 102, 241, 0.3);
}

.upload-icon {
  font-size: 36rpx;
}

.upload-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}
