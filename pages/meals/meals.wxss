.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.photo-list, .meal-list {
  margin-top: 12rpx;
}

.photo-item, .meal-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.photo-item:last-child, .meal-item:last-child {
  border-bottom: none;
}

.photo-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.photo-kcal {
  font-size: 30rpx;
  font-weight: 600;
  color: #6366f1;
}

.meal-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.meal-kcal {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.meal-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.meal-meta {
  display: flex;
  gap: 16rpx;
}
