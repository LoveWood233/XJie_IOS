<view class="container">
  <!-- 操作按钮 -->
  <view class="action-row">
    <button class="btn btn-primary flex-1" bindtap="choosePhoto" disabled="{{uploading}}" loading="{{uploading}}">
      📷 拍照记录
    </button>
    <button class="btn btn-outline flex-1" bindtap="addMealManual">
      ✏️ 手动记录
    </button>
  </view>

  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- 照片处理结果 -->
    <view class="card" wx:if="{{photos.length > 0}}">
      <view class="card-title">📸 照片分析</view>
      <view class="photo-list">
        <view class="photo-item" wx:for="{{photos}}" wx:key="id">
          <view class="photo-info">
            <text class="photo-status tag {{item.status === 'done' ? 'tag-success' : 'tag-warning'}}">{{item.status === 'done' ? '已完成' : '处理中'}}</text>
            <text class="photo-kcal" wx:if="{{item.calorie_estimate_kcal}}">{{toFixed(item.calorie_estimate_kcal, 0)}} kcal</text>
            <text class="text-muted">置信度: {{item.confidence ? toFixed(item.confidence * 100, 0) + '%' : '--'}}</text>
          </view>
          <text class="text-muted">{{formatDate(item.uploaded_at)}}</text>
        </view>
      </view>
    </view>

    <!-- 膳食记录列表 -->
    <view class="card" wx:if="{{meals.length > 0}}">
      <view class="card-title">🍽️ 膳食记录</view>
      <view class="meal-list">
        <view class="meal-item" wx:for="{{meals}}" wx:key="id">
          <view class="meal-main">
            <text class="meal-kcal">{{item.kcal || '--'}} kcal</text>
            <view class="meal-tags" wx:if="{{item.tags && item.tags.length > 0}}">
              <text class="tag tag-primary" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
          </view>
          <view class="meal-meta">
            <text class="text-muted">{{formatDate(item.meal_ts)}}</text>
            <text class="text-muted" wx:if="{{item.notes}}">{{item.notes}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{meals.length === 0 && photos.length === 0}}">
      <text class="empty-text">暂无膳食记录，点击上方按钮开始记录</text>
    </view>
  </block>
</view>
