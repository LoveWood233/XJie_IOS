<view class="container">
  <!-- 时间窗口切换 -->
  <view class="window-tabs">
    <view class="tab {{window === '24h' ? 'tab-active' : ''}}" data-w="24h" bindtap="switchWindow">24h</view>
    <view class="tab {{window === '7d' ? 'tab-active' : ''}}" data-w="7d" bindtap="switchWindow">7 天</view>
    <view class="tab {{window === 'all' ? 'tab-active' : ''}}" data-w="all" bindtap="switchWindow">全部</view>
  </view>

  <!-- 统计卡片 -->
  <view class="card" wx:if="{{summary}}">
    <view class="metric-row">
      <view class="metric-item">
        <text class="metric-value">{{summary.avg ? toFixed(summary.avg) : '--'}}</text>
        <text class="metric-label">平均</text>
      </view>
      <view class="metric-item">
        <text class="metric-value text-success">{{summary.tir_70_180_pct != null ? toFixed(summary.tir_70_180_pct) + '%' : '--'}}</text>
        <text class="metric-label">TIR</text>
      </view>
      <view class="metric-item">
        <text class="metric-value">{{summary.variability ? toFixed(summary.variability) : '--'}}</text>
        <text class="metric-label">变异性</text>
      </view>
      <view class="metric-item">
        <text class="metric-value">{{points.length}}</text>
        <text class="metric-label">数据点</text>
      </view>
    </view>
  </view>

  <!-- Canvas 图表 -->
  <view class="card chart-card">
    <view class="card-title">血糖曲线</view>
    <view class="loading-box" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>
    <block wx:elif="{{points.length > 0}}">
      <canvas type="2d" id="glucoseCanvas" class="glucose-canvas" style="width: {{canvasWidth}}px; height: 220px;"></canvas>
      <view class="chart-legend">
        <view class="legend-item"><view class="legend-dot dot-green"></view><text>目标范围 70-180</text></view>
        <view class="legend-item"><view class="legend-dot dot-purple"></view><text>血糖值</text></view>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <text class="empty-text">暂无血糖数据</text>
    </view>
  </view>
</view>
