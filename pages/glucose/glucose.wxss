.window-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #64748b;
  border-radius: 12rpx;
  font-weight: 500;
}

.tab-active {
  background: #6366f1;
  color: #ffffff;
}

.metric-row {
  display: flex;
  justify-content: space-between;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.metric-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

.metric-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.chart-card {
  padding-bottom: 16rpx;
}

.glucose-canvas {
  width: 100%;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-green {
  background: rgba(34, 197, 94, 0.4);
}

.dot-purple {
  background: #6366f1;
}
