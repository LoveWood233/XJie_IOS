<view class="login-page">
  <!-- Logo -->
  <view class="logo-area">
    <view class="logo-circle">
      <text class="logo-text">M</text>
    </view>
    <text class="app-name">MetaboDash</text>
    <text class="app-desc">智能代谢健康管理</text>
  </view>

  <!-- 微信一键登录 -->
  <view class="section">
    <button class="btn btn-primary btn-block wx-btn" bindtap="wxLogin" loading="{{loading}}">
      微信一键登录
    </button>
  </view>

  <!-- 分隔线 -->
  <view class="divider">
    <view class="divider-line"></view>
    <text class="divider-text">或</text>
    <view class="divider-line"></view>
  </view>

  <!-- 模式切换 -->
  <view class="mode-switch" bindtap="switchMode">
    <text class="text-primary">{{mode === 'subject' ? '使用邮箱登录' : '使用受试者 ID 登录'}}</text>
  </view>

  <!-- 受试者登录 -->
  <block wx:if="{{mode === 'subject'}}">
    <view class="section">
      <view class="card-title">选择受试者</view>
      <scroll-view scroll-y class="subject-list" wx:if="{{subjects.length > 0}}">
        <view
          wx:for="{{subjects}}" wx:key="subject_id"
          class="subject-item {{selectedSubject === item.subject_id ? 'selected' : ''}}"
          data-sid="{{item.subject_id}}"
          bindtap="onSubjectTap"
        >
          <text class="subject-id">{{item.subject_id}}</text>
          <text class="tag {{item.cohort === 'cgm' ? 'tag-primary' : 'tag-success'}}">{{item.cohort === 'cgm' ? 'CGM' : '肝脏'}}</text>
        </view>
      </scroll-view>
      <view wx:else class="empty-hint">
        <text class="text-muted">暂无可用受试者</text>
      </view>
      <button class="btn btn-primary btn-block" bindtap="loginSubject" disabled="{{!selectedSubject || loading}}" loading="{{loading}}">
        登录
      </button>
    </view>
  </block>

  <!-- 邮箱登录 -->
  <block wx:else>
    <view class="section">
      <view class="input-group">
        <text class="input-label">邮箱</text>
        <input class="input-field" type="text" placeholder="请输入邮箱" value="{{email}}" bindinput="onEmailInput" />
      </view>
      <view class="input-group">
        <text class="input-label">密码</text>
        <input class="input-field" type="password" placeholder="至少 8 位" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <button class="btn btn-primary btn-block" bindtap="loginEmail" disabled="{{loading}}" loading="{{loading}}">
        {{isSignup ? '注册' : '登录'}}
      </button>
      <view class="toggle-signup" bindtap="toggleSignup">
        <text class="text-primary">{{isSignup ? '已有账号？去登录' : '没有账号？去注册'}}</text>
      </view>
    </view>
  </block>
</view>
