.big-val {
  font-size: 48rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  display: block;
  margin-bottom: 8rpx;
}

.risk-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.goal-item {
  padding: 8rpx 0;
  font-size: 28rpx;
  color: #334155;
}

.rescue-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.rescue-title {
  font-weight: 600;
  display: block;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.ai-summary {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #334155;
  line-height: 1.8;
}
