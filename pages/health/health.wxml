<view class="container">
  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- 血糖状态 -->
    <view class="card" wx:if="{{briefing && briefing.glucose_status}}">
      <view class="card-title">📊 当前血糖状态</view>
      <view class="flex items-center gap-sm">
        <text class="big-val" wx:if="{{briefing.glucose_status.current_mgdl}}">{{toFixed(briefing.glucose_status.current_mgdl, 0)}} mg/dL</text>
        <text class="tag tag-primary" wx:if="{{briefing.glucose_status.trend}}">{{briefing.glucose_status.trend}}</text>
      </view>
      <text class="text-muted" wx:if="{{briefing.glucose_status.tir_24h != null}}">24h TIR: {{toFixed(briefing.glucose_status.tir_24h)}}%</text>
    </view>

    <!-- 每日计划 -->
    <view class="card" wx:if="{{briefing && briefing.daily_plan}}">
      <view class="card-title">📋 {{briefing.daily_plan.payload.title || '今日计划'}}</view>
      <!-- 风险窗口 -->
      <view wx:if="{{briefing.daily_plan.payload.risk_windows.length > 0}}">
        <text class="section-label">⚠ 风险窗口</text>
        <view class="risk-item" wx:for="{{briefing.daily_plan.payload.risk_windows}}" wx:key="start">
          <text>{{item.start}} - {{item.end}}</text>
          <text class="tag {{item.risk === 'high' ? 'tag-danger' : 'tag-warning'}}">{{item.risk}}</text>
        </view>
      </view>
      <!-- 目标 -->
      <view wx:if="{{briefing.daily_plan.payload.today_goals.length > 0}}" style="margin-top: 16rpx;">
        <text class="section-label">🎯 目标</text>
        <view wx:for="{{briefing.daily_plan.payload.today_goals}}" wx:key="*this" class="goal-item">
          <text>• {{item}}</text>
        </view>
      </view>
    </view>

    <!-- 待处理救援 -->
    <view class="card" wx:if="{{briefing && briefing.pending_rescues.length > 0}}">
      <view class="card-title text-danger">🚨 待处理救援</view>
      <view wx:for="{{briefing.pending_rescues}}" wx:key="id" class="rescue-item">
        <text class="rescue-title">{{item.payload.title}}</text>
        <text class="text-muted">{{item.payload.risk_level}}</text>
      </view>
    </view>

    <!-- 最近操作 -->
    <view class="card" wx:if="{{briefing && briefing.recent_actions.length > 0}}">
      <view class="card-title">📝 最近操作</view>
      <view wx:for="{{briefing.recent_actions}}" wx:key="id" class="action-item">
        <text class="tag tag-primary">{{item.action_type}}</text>
        <text class="text-muted" style="margin-left: 12rpx;">{{formatDate(item.created_ts)}}</text>
      </view>
    </view>

    <!-- 健康报告 (肝脏队列) -->
    <view class="card" wx:if="{{reports}}">
      <view class="card-title">🏥 健康报告</view>
      <block wx:if="{{reports.initial}}">
        <text class="section-label">初始检查</text>
        <text class="text-muted">{{reports.initial.date || ''}}</text>
      </block>
      <block wx:if="{{reports.final}}">
        <text class="section-label" style="margin-top: 16rpx;">结束检查</text>
        <text class="text-muted">{{reports.final.date || ''}}</text>
      </block>
      <button class="btn btn-outline" style="margin-top: 24rpx;" bindtap="loadAISummary" disabled="{{summaryLoading}}" loading="{{summaryLoading}}">
        生成 AI 摘要
      </button>
      <view class="ai-summary" wx:if="{{aiSummary}}">
        <text>{{aiSummary}}</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!briefing && !reports}}">
      <text class="empty-text">暂无健康数据</text>
    </view>
  </block>
</view>
