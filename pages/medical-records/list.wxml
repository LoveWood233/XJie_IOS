<view class="container">
  <!-- 上传按钮 -->
  <view class="upload-btn" bindtap="uploadRecord">
    <text class="upload-icon">📷</text>
    <text class="upload-label">上传病例</text>
  </view>

  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <view class="list" wx:if="{{items.length > 0}}">
      <view class="list-item" wx:for="{{items}}" wx:key="id">
        <view class="item-main" data-id="{{item.id}}" bindtap="viewDetail">
          <text class="item-name">{{item.name}}</text>
          <view class="item-meta">
            <text class="item-type tag">{{item.source_type === 'photo' ? '拍照' : item.source_type === 'csv' ? 'CSV' : 'PDF'}}</text>
            <text class="item-status tag {{item.extraction_status === 'done' ? 'tag-success' : 'tag-warning'}}">
              {{item.extraction_status === 'done' ? '已提取' : '处理中'}}
            </text>
            <text class="item-date">{{item.doc_date || ''}}</text>
          </view>
        </view>
        <view class="item-actions">
          <text class="del-btn" data-id="{{item.id}}" catchtap="deleteRecord">删除</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无病例记录</text>
      <text class="empty-sub">点击上方按钮上传病例</text>
    </view>
  </block>
</view>
