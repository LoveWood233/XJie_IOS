<view class="container">
  <!-- 顶部欢迎 -->
  <view class="welcome-bar flex items-center justify-between">
    <view>
      <text class="greeting">你好 👋</text>
      <text class="subject-label" wx:if="{{subjectId}}">{{subjectId}}</text>
    </view>
    <view class="avatar-circle" bindtap="goSettings">
      <text class="avatar-text">⚙</text>
    </view>
  </view>

  <!-- 主动消息卡片 -->
  <view class="card proactive-card" wx:if="{{proactive && proactive.message}}">
    <view class="flex items-center gap-sm">
      <text class="robot-icon">🤖</text>
      <text class="proactive-text">{{proactive.message}}</text>
    </view>
    <view class="rescue-badge" wx:if="{{proactive.has_rescue}}" bindtap="goRescue">
      <text class="text-danger">⚠ 有待处理的救援建议</text>
    </view>
  </view>

  <!-- 血糖概览 -->
  <view class="card" wx:if="{{dashboard && dashboard.glucose}}">
    <view class="card-title">📊 今日血糖</view>
    <view class="metric-row" wx:if="{{dashboard.glucose.last_24h}}">
      <view class="metric-item">
        <text class="metric-value">{{dashboard.glucose.last_24h.avg ? toFixed(dashboard.glucose.last_24h.avg) : '--'}}</text>
        <text class="metric-label">平均 mg/dL</text>
      </view>
      <view class="metric-item">
        <text class="metric-value text-success">{{dashboard.glucose.last_24h.tir_70_180_pct != null ? toFixed(dashboard.glucose.last_24h.tir_70_180_pct) + '%' : '--'}}</text>
        <text class="metric-label">TIR</text>
      </view>
      <view class="metric-item">
        <text class="metric-value">{{dashboard.glucose.last_24h.min ? toFixed(dashboard.glucose.last_24h.min, 0) : '--'}} - {{dashboard.glucose.last_24h.max ? toFixed(dashboard.glucose.last_24h.max, 0) : '--'}}</text>
        <text class="metric-label">范围</text>
      </view>
    </view>
  </view>

  <!-- 今日膳食 -->
  <view class="card">
    <view class="card-title">🍽️ 今日膳食</view>
    <view class="flex items-center justify-between">
      <text class="kcal-big">{{dashboard ? (dashboard.kcal_today || 0) : '--'}} kcal</text>
      <text class="text-muted">{{dashboard ? (dashboard.meals_today ? dashboard.meals_today.length : 0) : 0}} 餐</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-grid">
    <view class="quick-item" bindtap="goGlucose">
      <text class="quick-icon">📈</text>
      <text class="quick-label">血糖曲线</text>
    </view>
    <view class="quick-item" bindtap="goMeals">
      <text class="quick-icon">📷</text>
      <text class="quick-label">记录膳食</text>
    </view>
    <view class="quick-item" bindtap="goChat">
      <text class="quick-icon">💬</text>
      <text class="quick-label">AI 助手</text>
    </view>
    <view class="quick-item" bindtap="goToday">
      <text class="quick-icon">📋</text>
      <text class="quick-label">健康数据</text>
    </view>
  </view>

  <!-- 加载态 -->
  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
