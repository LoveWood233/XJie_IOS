.welcome-bar {
  margin-bottom: 24rpx;
}

.greeting {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.subject-label {
  font-size: 24rpx;
  color: #64748b;
}

.avatar-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 36rpx;
}

.proactive-card {
  border-left: 6rpx solid #6366f1;
}

.robot-icon {
  font-size: 40rpx;
}

.proactive-text {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
}

.rescue-badge {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(239, 68, 68, 0.06);
  border-radius: 8rpx;
}

.metric-row {
  display: flex;
  justify-content: space-between;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.metric-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.kcal-big {
  font-size: 40rpx;
  font-weight: 700;
  color: #6366f1;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 8rpx;
}

.quick-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.quick-item:active {
  opacity: 0.7;
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #334155;
}
