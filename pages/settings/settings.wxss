.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-label {
  color: #64748b;
  font-size: 26rpx;
}

.info-value {
  color: #1e293b;
  font-size: 26rpx;
  font-weight: 500;
}

.level-list {
  margin-top: 12rpx;
}

.level-item {
  padding: 24rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.level-item:active {
  opacity: 0.8;
}

.level-active {
  border-color: #6366f1;
  background: rgba(99, 102, 241, 0.04);
}

.level-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.level-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #6366f1;
}

.level-label {
  font-size: 26rpx;
  color: #334155;
  font-weight: 600;
}

.level-desc {
  font-size: 24rpx;
  color: #94a3b8;
}

.consent-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.consent-label {
  font-size: 28rpx;
  color: #334155;
}

.logout-btn {
  margin-top: 40rpx;
  color: #ef4444 !important;
  border-color: #ef4444 !important;
}
