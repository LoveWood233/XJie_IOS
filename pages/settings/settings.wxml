<view class="container">
  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- 用户信息 -->
    <view class="card">
      <view class="card-title">👤 账户信息</view>
      <view class="info-row">
        <text class="info-label">邮箱</text>
        <text class="info-value">{{user.email || '--'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">注册时间</text>
        <text class="info-value">{{user.created_at || '--'}}</text>
      </view>
    </view>

    <!-- 干预级别 -->
    <view class="card">
      <view class="card-title">⚡ 干预级别</view>
      <view class="level-list">
        <view
          wx:for="{{levels}}" wx:key="*this"
          class="level-item {{settings && settings.intervention_level === item ? 'level-active' : ''}}"
          data-level="{{item}}"
          bindtap="onLevelChange"
        >
          <view class="level-header">
            <text class="level-name">{{item}}</text>
            <text class="level-label">{{levelLabels[item]}}</text>
          </view>
          <text class="level-desc">{{levelDescs[item]}}</text>
        </view>
      </view>
    </view>

    <!-- 同意管理 -->
    <view class="card">
      <view class="card-title">🔒 隐私与同意</view>
      <view class="consent-row" bindtap="toggleAiChat">
        <text class="consent-label">允许 AI 聊天</text>
        <switch checked="{{user.consent.allow_ai_chat}}" color="#6366f1" />
      </view>
      <view class="consent-row" bindtap="toggleDataUpload">
        <text class="consent-label">允许数据上传</text>
        <switch checked="{{user.consent.allow_data_upload}}" color="#6366f1" />
      </view>
    </view>

    <!-- 退出 -->
    <button class="btn btn-outline btn-block logout-btn" bindtap="logout">
      退出登录
    </button>
  </block>
</view>
