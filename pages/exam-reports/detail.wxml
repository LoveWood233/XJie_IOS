<view class="container">
  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{doc}}">
    <!-- 标题 -->
    <view class="header-card">
      <text class="doc-name">{{doc.name}}</text>
      <view class="doc-meta">
        <text class="tag">{{doc.source_type === 'photo' ? '拍照上传' : doc.source_type === 'csv' ? 'CSV上传' : 'PDF上传'}}</text>
        <text class="tag {{doc.extraction_status === 'done' ? 'tag-success' : 'tag-warning'}}">
          {{doc.extraction_status === 'done' ? '已提取' : '处理中'}}
        </text>
        <text class="meta-date" wx:if="{{doc.doc_date}}">{{doc.doc_date}}</text>
      </view>
    </view>

    <!-- 异常提示 -->
    <view class="alert alert-danger" wx:if="{{doc.hasAbnormal}}">
      <text class="alert-icon">⚠️</text>
      <text class="alert-text">检测到 {{doc.abnormal_flags.length}} 项异常指标</text>
    </view>

    <!-- 异常详情卡片 -->
    <view class="abnormal-card" wx:if="{{doc.abnormal_flags && doc.abnormal_flags.length > 0}}">
      <text class="card-title">🚨 异常项目</text>
      <view class="abnormal-item" wx:for="{{doc.abnormal_flags}}" wx:key="index">
        <text class="abnormal-name">{{item.field || item.name || item}}</text>
        <text class="abnormal-value" wx:if="{{item.value}}">{{item.value}} {{item.unit || ''}}</text>
        <text class="abnormal-ref" wx:if="{{item.ref_range}}">参考: {{item.ref_range}}</text>
      </view>
    </view>

    <!-- 数据表格 -->
    <view class="table-card" wx:if="{{doc.csv_data && doc.csv_data.columns}}">
      <text class="card-title">📊 体检数据</text>
      <scroll-view scroll-x class="table-scroll">
        <view class="table">
          <view class="table-row table-header">
            <text class="table-cell header-cell" wx:for="{{doc.csv_data.columns}}" wx:key="*this">{{item}}</text>
          </view>
          <view class="table-row {{item.isAbnormal ? 'row-abnormal' : ''}}" wx:for="{{doc.csv_data.rows}}" wx:key="index">
            <text class="table-cell {{item.isAbnormal ? 'cell-abnormal' : ''}}" wx:for="{{item.cells}}" wx:for-item="cell" wx:key="*this">{{cell}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="empty-data" wx:else>
      <text class="text-muted">暂无提取数据（LLM 处理中）</text>
    </view>
  </block>

  <view class="empty-state" wx:else>
    <text class="text-muted">未找到该体检报告</text>
  </view>
</view>
