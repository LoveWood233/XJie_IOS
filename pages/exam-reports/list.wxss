.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #6366f1;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.upload-icon { font-size: 32rpx; }

.upload-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.item-main { flex: 1; }

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
  display: block;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.item-date {
  font-size: 24rpx;
  color: #94a3b8;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #64748b;
}

.tag-success { background: #dcfce7; color: #16a34a; }
.tag-warning { background: #fef3c7; color: #d97706; }
.tag-danger { background: #fee2e2; color: #dc2626; }

.del-btn {
  font-size: 24rpx;
  color: #ef4444;
  padding: 8rpx 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }

.empty-text {
  font-size: 30rpx;
  color: #64748b;
  font-weight: 500;
}

.empty-sub {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}
