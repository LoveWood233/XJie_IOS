.header-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.doc-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 12rpx;
}

.doc-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #64748b;
}

.tag-success { background: #dcfce7; color: #16a34a; }
.tag-warning { background: #fef3c7; color: #d97706; }

.meta-date {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ── 异常提示 ── */
.alert {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.alert-danger {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
}

.alert-icon { font-size: 32rpx; }

.alert-text {
  font-size: 28rpx;
  color: #dc2626;
  font-weight: 500;
}

/* ── 异常卡片 ── */
.abnormal-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 8rpx solid #ef4444;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
  display: block;
}

.abnormal-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #fef2f2;
  flex-wrap: wrap;
}

.abnormal-item:last-child { border-bottom: none; }

.abnormal-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #dc2626;
}

.abnormal-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.abnormal-ref {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ── 表格 ── */
.table-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.table-scroll { width: 100%; }
.table { min-width: 100%; }

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f1f5f9;
}

.table-row:last-child { border-bottom: none; }

.table-header {
  background: #f8fafc;
  border-radius: 8rpx 8rpx 0 0;
}

.row-abnormal {
  background: #fef2f2;
}

.table-cell {
  flex: 1;
  min-width: 160rpx;
  padding: 18rpx 16rpx;
  font-size: 26rpx;
  color: #334155;
  word-break: break-word;
}

.header-cell {
  font-weight: 600;
  color: #64748b;
  font-size: 24rpx;
}

.cell-abnormal {
  color: #dc2626;
  font-weight: 500;
}

.empty-data {
  text-align: center;
  padding: 60rpx 0;
}
