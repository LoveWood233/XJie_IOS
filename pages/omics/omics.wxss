/* ── Tab 切换栏 ── */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #64748b;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-active {
  background: #6366f1;
  color: #ffffff;
  font-weight: 600;
}

/* ── 面板 ── */
.panel {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.panel-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.panel-icon {
  font-size: 40rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

.panel-desc {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: block;
}

/* ── 指标列表 ── */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #e2e8f0;
}

.item-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-name {
  font-size: 28rpx;
  color: #334155;
  font-weight: 500;
}

.item-unit {
  font-size: 22rpx;
  color: #94a3b8;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.item-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.item-value.pending {
  color: #cbd5e1;
}

.item-status {
  font-size: 22rpx;
  color: #94a3b8;
  background: #f1f5f9;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* ── 底部说明 ── */
.footer-note {
  padding: 24rpx;
  text-align: center;
}

.note-text {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.6;
}
