<view class="container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === index ? 'tab-active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 蛋白组学 -->
  <view class="panel" wx:if="{{activeTab === 0}}">
    <view class="panel-header">
      <text class="panel-icon">{{proteomics.icon}}</text>
      <text class="panel-title">{{proteomics.title}}</text>
    </view>
    <text class="panel-desc">{{proteomics.desc}}</text>
    <view class="item-list">
      <view class="item-card" wx:for="{{proteomics.items}}" wx:key="name">
        <view class="item-left">
          <text class="item-name">{{item.name}}</text>
          <text class="item-unit" wx:if="{{item.unit}}">{{item.unit}}</text>
        </view>
        <view class="item-right">
          <text class="item-value pending">{{item.value}}</text>
          <text class="item-status">待检测</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 代谢组学 -->
  <view class="panel" wx:if="{{activeTab === 1}}">
    <view class="panel-header">
      <text class="panel-icon">{{metabolomics.icon}}</text>
      <text class="panel-title">{{metabolomics.title}}</text>
    </view>
    <text class="panel-desc">{{metabolomics.desc}}</text>
    <view class="item-list">
      <view class="item-card" wx:for="{{metabolomics.items}}" wx:key="name">
        <view class="item-left">
          <text class="item-name">{{item.name}}</text>
          <text class="item-unit" wx:if="{{item.unit}}">{{item.unit}}</text>
        </view>
        <view class="item-right">
          <text class="item-value pending">{{item.value}}</text>
          <text class="item-status">待检测</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 基因组学 -->
  <view class="panel" wx:if="{{activeTab === 2}}">
    <view class="panel-header">
      <text class="panel-icon">{{genomics.icon}}</text>
      <text class="panel-title">{{genomics.title}}</text>
    </view>
    <text class="panel-desc">{{genomics.desc}}</text>
    <view class="item-list">
      <view class="item-card" wx:for="{{genomics.items}}" wx:key="name">
        <view class="item-left">
          <text class="item-name">{{item.name}}</text>
          <text class="item-unit" wx:if="{{item.unit}}">{{item.unit}}</text>
        </view>
        <view class="item-right">
          <text class="item-value pending">{{item.value}}</text>
          <text class="item-status">待检测</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer-note">
    <text class="note-text">📋 多组学数据需通过专业机构检测后上传，当前为占位展示。</text>
  </view>
</view>
